<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.jinyou.mapper.BannerMapper">

<!--    动态sql-->
    <select id="list" resultType="com.jinyou.pojo.Banner">
        select * from banner
        <where>
            <if test="status != null">
                AND status = #{status}
            </if>
            <if test="title != null and title != ''">
                title like concat('%', #{title}, '%')
            </if>
            and create_user = #{userId}
        </where>
        ORDER BY sort DESC
    </select>
</mapper>